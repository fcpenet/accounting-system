# ---------------------------------------------------------------------------
# Turso (libSQL)
# ---------------------------------------------------------------------------
# Local development against a file — no auth token needed:
#   TURSO_DATABASE_URL="file:./local.db"
#
# Turso cloud (get both values with the Turso CLI):
#   turso db create accounting
#   turso db show accounting --url
#   turso db tokens create accounting
TURSO_DATABASE_URL="file:./local.db"
TURSO_AUTH_TOKEN=""
