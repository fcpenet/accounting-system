{
  "name": "@acct/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "dotenv -e ../../.env.local -- drizzle-kit migrate",
    "push": "dotenv -e ../../.env.local -- drizzle-kit push",
    "studio": "dotenv -e ../../.env.local -- drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@acct/core": "workspace:*",
    "@libsql/client": "^0.15.9",
    "drizzle-orm": "^0.44.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
