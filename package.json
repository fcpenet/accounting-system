{
  "name": "accounting-system",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "db:generate": "pnpm --filter db generate",
    "db:migrate": "pnpm --filter db migrate",
    "db:push": "pnpm --filter db push",
    "db:studio": "pnpm --filter db studio",
    "db:seed": "dotenv -e .env.local -- tsx scripts/seed.ts",
    "db:verify": "dotenv -e .env.local -- tsx scripts/verify.ts",
    "dev:session": "dotenv -e .env.local -- tsx scripts/dev-session.ts"
  },
  "dependencies": {
    "@acct/auth": "workspace:*",
    "@acct/core": "workspace:*",
    "@acct/db": "workspace:*",
    "@acct/ledger": "workspace:*"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@libsql/client",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.29.2"
}
